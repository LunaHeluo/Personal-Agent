# Only secrets belong here. Copy this file to .env.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
OLLAMA_API_KEY=ollama
TOKENROUTER_API_KEY=
ZHIPU_API_KEY=
