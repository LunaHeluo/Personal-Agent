# Optional email profile secrets. Keep real values only in the local .env or
# system environment; never copy them into YAML, logs, fixtures, or source.
EMAIL_ACCOUNT=
EMAIL_CREDENTIAL=
EMAIL_OAUTH_CLIENT_ID=
EMAIL_OAUTH_REFRESH_TOKEN=

